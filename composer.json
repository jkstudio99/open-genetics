{
    "name": "open-genetics/framework",
    "version": "2.2.0",
    "description": "Enterprise PHP Micro-Framework — JWT Auth, Genetic RBAC, Query Builder, i18n, Audit Trail, Testing Framework, and Dual-Frontend SDK",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "micro-framework",
        "rest-api",
        "jwt",
        "rbac",
        "i18n",
        "audit-trail",
        "psr-4"
    ],
    "homepage": "https://github.com/open-genetics/framework",
    "authors": [
        {
            "name": "OpenGenetics Team",
            "homepage": "https://github.com/open-genetics"
        }
    ],
    "support": {
        "issues": "https://github.com/open-genetics/framework/issues",
        "source": "https://github.com/open-genetics/framework",
        "docs": "https://github.com/open-genetics/framework/tree/main/docs/site"
    },
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "firebase/php-jwt": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "OpenGenetics\\": "src/"
        }
    },
    "bin": [
        "genetics"
    ],
    "scripts": {
        "post-create-project-cmd": [
            "php -r \"copy('.env.example', '.env');\"",
            "php -r \"file_put_contents('.env', str_replace('your-secret-key-change-this', bin2hex(random_bytes(32)), file_get_contents('.env')));\"",
            "@php genetics help"
        ],
        "mutate": "php genetics mutate",
        "seed": "php genetics seed",
        "serve": "php genetics serve",
        "test": "phpunit"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
