#!/usr/bin/env php
<?php

/**
 * 🧬 OpenGenetics — Genetic CLI
 *
 * Install globally:
 *   composer global require open-genetics/framework
 *   genetics new my-project
 *
 * Project commands:
 *   php genetics mutate            — Create tables & seed RBAC
 *   php genetics seed              — Seed RBAC roles & admin user
 *   php genetics status            — Show database connection status
 *   php genetics make:endpoint     — Scaffold a new API endpoint
 *   php genetics make:middleware   — Scaffold a new middleware
 *   php genetics docs:generate     — Auto-generate OpenAPI spec from `api/`
 *   php genetics serve             — Start PHP development server
 *   php genetics new <name>        — Create a new OpenGenetics project
 *   php genetics help              — Show this help message
 */

declare(strict_types=1);

// ─── Resolve project root ───
// When installed globally via composer, __DIR__ = ~/.composer/vendor/open-genetics/framework/bin
// When used locally, __DIR__ = /path/to/project/bin
$projectRoot = findProjectRoot();

// Banner
echo "\n";
echo "  ╔═══════════════════════════════════════════╗\n";
echo "  ║  🧬 OpenGenetics — Genetic CLI  v2.0.3    ║\n";
echo "  ║  Enterprise PHP Micro-Framework            ║\n";
echo "  ╚═══════════════════════════════════════════╝\n";
echo "\n";

// Parse command
$command = $argv[1] ?? 'help';

// Commands that don't need a project context
if ($command === 'new') {
    newProject($argv[2] ?? null);
    exit(0);
}

if ($command === 'help' || $command === '--help' || $command === '-h') {
    help();
    exit(0);
}

if ($command === '--version' || $command === '-v') {
    echo "  OpenGenetics Framework v2.0.3\n\n";
    exit(0);
}

if ($command === 'serve') {
    serve($projectRoot);
    exit(0);
}

// Commands that require a project context — bootstrap the framework
if (!$projectRoot) {
    echo "  ❌ No OpenGenetics project found in current directory.\n";
    echo "  Run `genetics new my-project` to create one.\n\n";
    exit(1);
}

bootstrapProject($projectRoot);

match ($command) {
    'mutate'            => mutate(),
    'seed'              => seed(),
    'status'            => status(),
    'migrate'           => cliMigrate($projectRoot),
    'migrate:rollback'  => cliMigrateRollback($projectRoot),
    'migrate:status'    => cliMigrateStatus($projectRoot),
    'make:endpoint'     => makeEndpoint($projectRoot, $argv[2] ?? null),
    'make:middleware'   => makeMiddleware($projectRoot, $argv[2] ?? null),
    'make:migration'    => cliMakeMigration($projectRoot, $argv[2] ?? null),
    'make:test'         => cliMakeTest($projectRoot, $argv[2] ?? null),
    'make:admin'        => cliMakeAdmin($projectRoot, $argv[2] ?? null),
    'make:endpoint-ai'  => cliMakeEndpointAI($projectRoot, $argv[2] ?? null, $argv[3] ?? ''),
    'cache:clear'       => cliCacheClear($projectRoot),
    'cache:stats'       => cliCacheStats($projectRoot),
    'cache:gc'          => cliCacheGc($projectRoot),
    'market:list'       => cliMarketList($projectRoot, $argv[2] ?? null),
    'market:search'     => cliMarketSearch($argv[2] ?? null),
    'market:install'    => cliMarketInstall($projectRoot, $argv[2] ?? null),
    'modules:list'      => cliModulesList($projectRoot),
    'docs:generate'     => generateDocs($projectRoot),
    default             => unknownCommand($command),
};

// ═══════════════════════════════════════════════════════
// Helper: Find project root
// ═══════════════════════════════════════════════════════

function findProjectRoot(): ?string
{
    $dir = getcwd();
    for ($i = 0; $i < 6; $i++) {
        // Has composer.json with open-genetics/framework dependency
        if (file_exists($dir . '/composer.json')) {
            $json = json_decode(file_get_contents($dir . '/composer.json'), true);
            if (isset($json['require']['open-genetics/framework'])) {
                return $dir;
            }
        }
        // Has vendor/open-genetics (already installed)
        if (is_dir($dir . '/vendor/open-genetics/framework')) {
            return $dir;
        }
        $parent = dirname($dir);
        if ($parent === $dir) break;
        $dir = $parent;
    }

    // Fallback: running from inside vendor (global install)
    $scriptDir = dirname(__DIR__);
    if (file_exists($scriptDir . '/composer.json')) {
        $json = json_decode(file_get_contents($scriptDir . '/composer.json'), true);
        if (isset($json['require']['open-genetics/framework'])) {
            return $scriptDir;
        }
    }

    return null;
}

function bootstrapProject(string $root): void
{
    // Load autoloader
    $autoload = $root . '/vendor/autoload.php';
    if (file_exists($autoload)) {
        require_once $autoload;
    }

    // Load bootstrap if exists (full framework install)
    $bootstrap = $root . '/src/bootstrap.php';
    if (file_exists($bootstrap)) {
        require_once $bootstrap;
    }

    // Load .env
    if (class_exists('\OpenGenetics\Core\Env')) {
        \OpenGenetics\Core\Env::load($root);
    } elseif (file_exists($root . '/.env')) {
        foreach (file($root . '/.env') as $line) {
            $line = trim($line);
            if ($line && !str_starts_with($line, '#') && str_contains($line, '=')) {
                [$k, $v] = explode('=', $line, 2);
                $_ENV[trim($k)] = trim($v);
                putenv(trim($k) . '=' . trim($v));
            }
        }
    }
}

// ═══════════════════════════════════════════════════════
// Command: new — Create a new project
// ═══════════════════════════════════════════════════════

function newProject(?string $name): void
{
    if (empty($name)) {
        echo "  ❌ Usage: genetics new <project-name>\n";
        echo "  Example: genetics new my-api\n\n";
        return;
    }

    $targetDir = getcwd() . '/' . $name;

    if (is_dir($targetDir)) {
        echo "  ❌ Directory '{$name}' already exists.\n\n";
        return;
    }

    echo "  📦 Creating new OpenGenetics project: {$name}\n\n";

    // Determine skeleton source
    $skeletonDir = findSkeletonDir();

    if (!$skeletonDir) {
        // Fallback: create from scratch
        echo "  📁 Creating project structure...\n";
        createProjectFromScratch($targetDir, $name);
    } else {
        echo "  📁 Copying project skeleton...\n";
        copyDirectory($skeletonDir, $targetDir, [
            'vendor', '.git', '.DS_Store', '.env',
            'node_modules', 'bin',
        ]);
    }

    // Create .env from example
    if (file_exists($targetDir . '/.env.example')) {
        copy($targetDir . '/.env.example', $targetDir . '/.env');
        echo "  ✅ .env created from .env.example\n";
    }

    // Generate JWT secret
    $envFile = $targetDir . '/.env';
    if (file_exists($envFile)) {
        $env = file_get_contents($envFile);
        $secret = bin2hex(random_bytes(32));
        $env = str_replace(
            'JWT_SECRET=your-secret-key-change-this',
            'JWT_SECRET=' . $secret,
            $env
        );
        file_put_contents($envFile, $env);
        echo "  🔑 JWT_SECRET generated\n";
    }

    echo "\n  ✅ Project created: {$name}/\n\n";
    echo "  Next steps:\n";
    echo "    cd {$name}\n";
    echo "    composer install\n";
    echo "    php add/genetics mutate\n";
    echo "    php add/genetics serve\n\n";
}

function findSkeletonDir(): ?string
{
    // When installed globally, skeleton is at the package root
    $packageRoot = dirname(__DIR__);
    if (file_exists($packageRoot . '/src/bootstrap.php') && file_exists($packageRoot . '/api')) {
        return $packageRoot;
    }
    return null;
}

function copyDirectory(string $src, string $dst, array $exclude = []): void
{
    if (!is_dir($dst)) {
        mkdir($dst, 0755, true);
    }

    $items = scandir($src);
    foreach ($items as $item) {
        if ($item === '.' || $item === '..') continue;
        if (in_array($item, $exclude, true)) continue;

        $srcPath = $src . '/' . $item;
        $dstPath = $dst . '/' . $item;

        if (is_dir($srcPath)) {
            copyDirectory($srcPath, $dstPath, $exclude);
        } else {
            copy($srcPath, $dstPath);
        }
    }
}

function createProjectFromScratch(string $dir, string $name): void
{
    // Create directory structure
    $dirs = [
        '', 'api', 'api/auth', 'src', 'src/Auth', 'src/Audit',
        'src/Core', 'src/I18n', 'public', 'public/styles',
        'locales', 'sdk', 'bin',
    ];

    foreach ($dirs as $d) {
        mkdir($dir . '/' . $d, 0755, true);
    }

    // Create composer.json for the new project
    $composerJson = json_encode([
        'name' => 'my-project/' . $name,
        'description' => 'An OpenGenetics API project',
        'type' => 'project',
        'license' => 'MIT',
        'require' => [
            'php' => '>=8.1',
            'open-genetics/framework' => '^2.0',
        ],
        'autoload' => [
            'psr-4' => ['App\\' => 'src/'],
        ],
        'scripts' => [
            'mutate' => 'php genetics mutate',
            'seed'   => 'php genetics seed',
            'serve'  => 'php genetics serve',
        ],
    ], JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES);

    file_put_contents($dir . '/composer.json', $composerJson . "\n");
    echo "  ✅ composer.json\n";

    // Create .env.example
    $envExample = <<<'ENV'
DB_HOST=localhost
DB_PORT=3306
DB_NAME=my-api-db
DB_USER=root
DB_PASS=

JWT_SECRET=your-secret-key-change-this
JWT_EXPIRATION=86400

APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=Asia/Bangkok

CORS_ORIGIN=*
BCRYPT_COST=12
ENV;

    file_put_contents($dir . '/.env.example', $envExample . "\n");
    echo "  ✅ .env.example\n";

    // Create .gitignore
    $gitignore = <<<'GIT'
/vendor/
node_modules/
.env
.idea/
.vscode/
*.swp
.DS_Store
*.log
GIT;

    file_put_contents($dir . '/.gitignore', $gitignore . "\n");
    echo "  ✅ .gitignore\n";

    // Create genetics proxy script
    $geneticsProxy = <<<'PHP'
#!/usr/bin/env php
<?php
$vendorGenetics = __DIR__ . '/vendor/open-genetics/framework/genetics';
if (!file_exists($vendorGenetics)) {
    echo "  ❌ Run 'composer install' first.\n";
    exit(1);
}
require $vendorGenetics;
PHP;

    file_put_contents($dir . '/genetics', $geneticsProxy . "\n");
    chmod($dir . '/genetics', 0755);
    echo "  ✅ genetics\n";

    echo "  ✅ Directory structure created\n";
}

// ═══════════════════════════════════════════════════════
// Command: serve — Start dev server
// ═══════════════════════════════════════════════════════

function serve(?string $root): void
{
    if (!$root) {
        echo "  ❌ No OpenGenetics project found.\n\n";
        return;
    }

    $host = '127.0.0.1';
    $port = 8080;

    // Find available port
    for ($p = $port; $p <= 8099; $p++) {
        $sock = @fsockopen($host, $p, $errno, $errstr, 0.1);
        if ($sock) {
            fclose($sock);
            continue;
        }
        $port = $p;
        break;
    }

    $publicDir = $root . '/public';

    echo "  🚀 Starting development server...\n";
    echo "  🌐 http://{$host}:{$port}\n";
    echo "  📂 Document root: {$publicDir}\n";
    echo "  Press Ctrl+C to stop.\n\n";

    passthru("php -S {$host}:{$port} -t " . escapeshellarg($publicDir));
}

// ═══════════════════════════════════════════════════════
// Command: mutate — Create database tables
// ═══════════════════════════════════════════════════════

function mutate(): void
{
    echo "  🔬 Mutating database schema...\n\n";

    $pdo = \OpenGenetics\Core\Database::connect();

    $statements = [
        'roles' => "CREATE TABLE IF NOT EXISTS `roles` (
            `id` INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
            `role_name` VARCHAR(50) NOT NULL UNIQUE,
            `description` VARCHAR(255) DEFAULT NULL,
            `created_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci",

        'users' => "CREATE TABLE IF NOT EXISTS `users` (
            `id` INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
            `email` VARCHAR(255) NOT NULL UNIQUE,
            `password_hash` VARCHAR(255) NOT NULL,
            `role_id` INT UNSIGNED NOT NULL DEFAULT 3,
            `is_active` TINYINT(1) NOT NULL DEFAULT 1,
            `tenant_id` VARCHAR(100) DEFAULT NULL,
            `created_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            `updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
            CONSTRAINT `fk_users_role` FOREIGN KEY (`role_id`) REFERENCES `roles`(`id`)
                ON DELETE RESTRICT ON UPDATE CASCADE,
            INDEX `idx_users_email` (`email`),
            INDEX `idx_users_role` (`role_id`),
            INDEX `idx_users_tenant` (`tenant_id`),
            INDEX `idx_users_active` (`is_active`)
        ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci",

        'password_resets' => "CREATE TABLE IF NOT EXISTS `password_resets` (
            `id` INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
            `email` VARCHAR(255) NOT NULL,
            `token` VARCHAR(255) NOT NULL UNIQUE,
            `expires_at` TIMESTAMP NOT NULL,
            `created_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            INDEX `idx_resets_email` (`email`),
            INDEX `idx_resets_token` (`token`),
            INDEX `idx_resets_expires` (`expires_at`)
        ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci",

        'audit_logs' => "CREATE TABLE IF NOT EXISTS `audit_logs` (
            `id` BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
            `user_id` INT UNSIGNED DEFAULT NULL,
            `action` VARCHAR(50) NOT NULL,
            `entity` VARCHAR(100) NOT NULL,
            `payload` JSON DEFAULT NULL,
            `ip_address` VARCHAR(45) DEFAULT NULL,
            `user_agent` VARCHAR(500) DEFAULT NULL,
            `created_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            CONSTRAINT `fk_audit_user` FOREIGN KEY (`user_id`) REFERENCES `users`(`id`)
                ON DELETE SET NULL ON UPDATE CASCADE,
            INDEX `idx_audit_user` (`user_id`),
            INDEX `idx_audit_action` (`action`),
            INDEX `idx_audit_entity` (`entity`),
            INDEX `idx_audit_created` (`created_at`)
        ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci",
    ];

    foreach ($statements as $table => $sql) {
        try {
            $pdo->exec($sql);
            echo "  ✅ Table `{$table}` — created/verified\n";
        } catch (\PDOException $e) {
            echo "  ❌ Error ({$table}): " . $e->getMessage() . "\n";
        }
    }

    echo "\n  🧬 Mutation complete!\n\n";

    // Auto-seed after mutation
    seed();
}

// ═══════════════════════════════════════════════════════
// Command: seed — Seed RBAC data
// ═══════════════════════════════════════════════════════

function seed(): void
{
    echo "  🌱 Seeding RBAC data...\n\n";

    $pdo = \OpenGenetics\Core\Database::connect();

    // Seed roles
    $roles = [
        [1, 'ADMIN', 'Full system administrator'],
        [2, 'MANAGER', 'Manager'],
        [3, 'EMPLOYEE', 'Regular employee'],
    ];

    foreach ($roles as [$id, $name, $desc]) {
        try {
            $stmt = $pdo->prepare(
                "INSERT INTO `roles` (`id`, `role_name`, `description`)
                 VALUES (:id, :name, :desc)
                 ON DUPLICATE KEY UPDATE `description` = VALUES(`description`)"
            );
            $stmt->execute(['id' => $id, 'name' => $name, 'desc' => $desc]);
            echo "  ✅ Role `{$name}` — seeded\n";
        } catch (\PDOException $e) {
            echo "  ⚠️  Role `{$name}`: " . $e->getMessage() . "\n";
        }
    }

    // Seed admin user
    $adminEmail = 'admin@opengenetics.io';
    $adminPass  = password_hash('password', PASSWORD_BCRYPT, ['cost' => 12]);

    try {
        $existing = \OpenGenetics\Core\Database::query(
            "SELECT id FROM users WHERE email = :email",
            ['email' => $adminEmail]
        );

        if (empty($existing)) {
            \OpenGenetics\Core\Database::execute(
                "INSERT INTO `users` (`email`, `password_hash`, `role_id`, `is_active`)
                 VALUES (:email, :hash, 1, 1)",
                ['email' => $adminEmail, 'hash' => $adminPass]
            );
            echo "  ✅ Admin user `{$adminEmail}` — created\n";
        } else {
            echo "  ℹ️  Admin user `{$adminEmail}` — already exists\n";
        }
    } catch (\PDOException $e) {
        echo "  ❌ Admin seeding error: " . $e->getMessage() . "\n";
    }

    echo "\n  🌱 Seeding complete!\n\n";
}

// ═══════════════════════════════════════════════════════
// Command: status — Check database
// ═══════════════════════════════════════════════════════

function status(): void
{
    echo "  📊 Checking database connection...\n\n";

    try {
        $pdo = \OpenGenetics\Core\Database::connect();
        $info = $pdo->getAttribute(\PDO::ATTR_SERVER_VERSION);
        echo "  ✅ Connected to MySQL {$info}\n";
        echo "  📦 Database: " . \OpenGenetics\Core\Env::get('DB_NAME') . "\n";
        echo "  🖥️  Host: " . \OpenGenetics\Core\Env::get('DB_HOST') . ":" . \OpenGenetics\Core\Env::get('DB_PORT') . "\n";

        // Count tables
        $tables = $pdo->query("SHOW TABLES")->fetchAll(\PDO::FETCH_COLUMN);
        echo "  📋 Tables: " . count($tables) . " (" . implode(', ', $tables) . ")\n";
    } catch (\Throwable $e) {
        echo "  ❌ Connection failed: " . $e->getMessage() . "\n";
    }

    echo "\n";
}

// ═══════════════════════════════════════════════════════
// Command: make:endpoint — Scaffold API endpoint
// ═══════════════════════════════════════════════════════

function makeEndpoint(string $root, ?string $name): void
{
    if (empty($name)) {
        echo "  ❌ Usage: php add/genetics make:endpoint <name>\n";
        echo "  Example: php add/genetics make:endpoint users/export\n\n";
        return;
    }

    $name = trim($name, '/');
    $filePath = $root . '/api/' . $name . '.php';

    if (file_exists($filePath)) {
        echo "  ⚠️  Endpoint already exists: api/{$name}.php\n\n";
        return;
    }

    // Create directory if needed
    $dir = dirname($filePath);
    if (!is_dir($dir)) {
        mkdir($dir, 0755, true);
    }

    // Generate PascalCase class name
    $parts = explode('/', $name);
    $className = '';
    foreach ($parts as $part) {
        $segments = explode('-', $part);
        $className .= implode('', array_map('ucfirst', $segments));
    }

    $template = <<<PHP
<?php

/**
 * GET|POST /api/{$name}
 *
 * Auto-generated endpoint via `php add/genetics make:endpoint`.
 */

use OpenGenetics\Auth\Guard;
use OpenGenetics\Core\Database;
use OpenGenetics\Core\Response;

class {$className}
{
    public static function get(array \$body): void
    {
        Guard::requireAuth();

        Response::success(['message' => '{$className} endpoint works']);
    }

    public static function post(array \$body): void
    {
        Guard::requireAuth();

        // TODO: Implement POST handler
        Response::success(null, 'Created', 201);
    }
}

PHP;

    file_put_contents($filePath, $template);
    echo "  ✅ Created endpoint: api/{$name}.php\n";
    echo "  📝 Class: {$className}\n";
    echo "  🔗 Route: GET|POST /api/{$name}\n\n";
}

// ═══════════════════════════════════════════════════════
// Command: make:middleware — Scaffold middleware
// ═══════════════════════════════════════════════════════

function makeMiddleware(string $root, ?string $name): void
{
    if (empty($name)) {
        echo "  ❌ Usage: php add/genetics make:middleware <Name>\n";
        echo "  Example: php add/genetics make:middleware RateLimit\n\n";
        return;
    }

    $className = ucfirst($name);
    if (!str_ends_with($className, 'Middleware')) {
        $className .= 'Middleware';
    }

    $filePath = $root . '/src/Middleware/' . $className . '.php';

    if (file_exists($filePath)) {
        echo "  ⚠️  Middleware already exists: src/Middleware/{$className}.php\n\n";
        return;
    }

    $dir = dirname($filePath);
    if (!is_dir($dir)) {
        mkdir($dir, 0755, true);
    }

    // Generate alias name: CacheMiddleware → cache
    $nameAlias = strtolower(str_replace('Middleware', '', $className));

    $template = <<<PHP
<?php

declare(strict_types=1);

namespace OpenGenetics\Middleware;

/**
 * {$className} Middleware
 *
 * Auto-generated via `php add/genetics make:middleware`.
 * Register via: Pipeline::alias('{$nameAlias}', {$className}::class);
 * Use in endpoints: #[Middleware('{$nameAlias}')]
 */
final class {$className}
{
    public function handle(array \$request, callable \$next): void
    {
        // TODO: Add pre-processing logic here
        // Example: Validate headers, check permissions, etc.

        // Pass to next middleware
        \$next(\$request);
    }
}

PHP;

    file_put_contents($filePath, $template);
    echo "  ✅ Created middleware: src/Middleware/{$className}.php\n";
    echo "  📝 Namespace: OpenGenetics\\Middleware\\{$className}\n";
    echo "  💡 Register: Pipeline::alias('{$nameAlias}', {$className}::class);\n\n";
}

// ═══════════════════════════════════════════════════════
// Command: docs:generate — Auto-generate OpenAPI spec
// ═══════════════════════════════════════════════════════

function generateDocs(string $root): void
{
    echo "  📚 Scanning `api/` directory for endpoints...\n\n";

    $apiDir = $root . '/api';
    $outputPath = $root . '/public/openapi.json';

    $generator = new \OpenGenetics\Core\OpenApiGenerator($apiDir);

    if ($generator->generate($outputPath)) {
        echo "  ✅ OpenAPI specification generated successfully!\n";
        echo "  📄 Saved to: public/openapi.json\n\n";
    } else {
        echo "  ❌ Failed to generate OpenAPI specification.\n\n";
    }
}

// ═══════════════════════════════════════════════════════
// Command: migrate — Run pending migrations
// ═══════════════════════════════════════════════════════

function cliMigrate(string $root): void
{
    echo "  🔄 Running pending migrations...\n\n";

    $migrator = new \OpenGenetics\Core\Migrator($root);
    $executed = $migrator->migrate();

    if (empty($executed)) {
        echo "  ℹ️  Nothing to migrate — all up to date.\n\n";
        return;
    }

    foreach ($executed as $name) {
        echo "  ✅ Migrated: {$name}\n";
    }

    echo "\n  🧬 " . count($executed) . " migration(s) executed.\n\n";
}

// ═══════════════════════════════════════════════════════
// Command: migrate:rollback — Undo last batch
// ═══════════════════════════════════════════════════════

function cliMigrateRollback(string $root): void
{
    echo "  ⏪ Rolling back last migration batch...\n\n";

    $migrator   = new \OpenGenetics\Core\Migrator($root);
    $rolledBack = $migrator->rollback();

    if (empty($rolledBack)) {
        echo "  ℹ️  Nothing to rollback.\n\n";
        return;
    }

    foreach ($rolledBack as $name) {
        echo "  ↩️  Rolled back: {$name}\n";
    }

    echo "\n  🧬 " . count($rolledBack) . " migration(s) rolled back.\n\n";
}

// ═══════════════════════════════════════════════════════
// Command: migrate:status — Show migration status
// ═══════════════════════════════════════════════════════

function cliMigrateStatus(string $root): void
{
    echo "  📋 Migration Status\n\n";

    $migrator = new \OpenGenetics\Core\Migrator($root);
    $statuses = $migrator->status();

    if (empty($statuses)) {
        echo "  ℹ️  No migration files found.\n\n";
        return;
    }

    printf("  %-50s %-10s %-8s %s\n", 'Migration', 'Status', 'Batch', 'Date');
    echo "  " . str_repeat('─', 90) . "\n";

    foreach ($statuses as $s) {
        $icon = $s['status'] === 'Ran' ? '✅' : '⏳';
        printf("  %s %-48s %-10s %-8s %s\n",
            $icon,
            $s['name'],
            $s['status'],
            $s['batch'] ?? '—',
            $s['date'] ?? '—'
        );
    }

    echo "\n";
}

// ═══════════════════════════════════════════════════════
// Command: make:migration — Create migration file
// ═══════════════════════════════════════════════════════

function cliMakeMigration(string $root, ?string $name): void
{
    if (empty($name)) {
        echo "  ❌ Usage: php add/genetics make:migration <name>\n";
        echo "  Example: php add/genetics make:migration add_image_to_equipment\n\n";
        return;
    }

    $migrator = new \OpenGenetics\Core\Migrator($root);
    $path     = $migrator->createMigration($name);
    $basename = basename($path);

    echo "  ✅ Created migration: database/migrations/{$basename}\n\n";
}

// ═══════════════════════════════════════════════════════
// Command: make:test — Create test class
// ═══════════════════════════════════════════════════════

function cliMakeTest(string $root, ?string $name): void
{
    if (empty($name)) {
        echo "  ❌ Usage: php add/genetics make:test <Name>\n";
        echo "  Example: php add/genetics make:test UsersTest\n\n";
        return;
    }

    $className = ucfirst($name);
    if (!str_ends_with($className, 'Test')) {
        $className .= 'Test';
    }

    $filePath = $root . '/tests/' . $className . '.php';

    if (file_exists($filePath)) {
        echo "  ⚠️  Test already exists: tests/{$className}.php\n\n";
        return;
    }

    $dir = dirname($filePath);
    if (!is_dir($dir)) {
        mkdir($dir, 0755, true);
    }

    $template = <<<PHP
<?php

use OpenGenetics\Testing\GeneticTestCase;

/**
 * {$className}
 *
 * Auto-generated via `php add/genetics make:test`.
 */
class {$className} extends GeneticTestCase
{
    public function testExample(): void
    {
        \$this->actingAsAdmin();

        \$response = \$this->get('/api/health');
        \$response->assertOk()->assertSuccess();
    }
}

PHP;

    file_put_contents($filePath, $template);
    echo "  ✅ Created test: tests/{$className}.php\n";
    echo "  🧪 Run with: vendor/bin/phpunit tests/{$className}.php\n\n";
}

// ═══════════════════════════════════════════════════════
// Commands: cache:clear, cache:stats, cache:gc
// ═══════════════════════════════════════════════════════

function cliCacheClear(string $root): void
{
    bootstrapProject($root);
    \OpenGenetics\Core\Cache::clear();
    echo "  ✅ Cache cleared.\n\n";
}

function cliCacheStats(string $root): void
{
    bootstrapProject($root);
    $stats = \OpenGenetics\Core\Cache::stats();
    echo "  📊 Cache Stats\n";
    echo "  " . str_repeat('─', 40) . "\n";
    printf("  %-20s %s\n", 'Total entries:',  $stats['entries']);
    printf("  %-20s %s\n", 'Expired entries:', $stats['expired']);
    printf("  %-20s %s KB\n", 'Disk size:',   $stats['size_kb']);
    echo "\n  Tags:\n";
    foreach ($stats['tags'] as $tag => $count) {
        echo "    {$tag}: {$count} entries\n";
    }
    echo "\n";
}

function cliCacheGc(string $root): void
{
    bootstrapProject($root);
    $removed = \OpenGenetics\Core\Cache::gc();
    echo "  🧹 Cache GC: removed {$removed} expired entr" . ($removed === 1 ? 'y' : 'ies') . ".\n\n";
}

// ═══════════════════════════════════════════════════════
// Command: make:admin — Generate CRUD admin endpoint
// ═══════════════════════════════════════════════════════

function cliMakeAdmin(string $root, ?string $table): void
{
    if (empty($table)) {
        echo "  ❌ Usage: php add/genetics make:admin <table>\n";
        echo "  Example: php add/genetics make:admin products\n\n";
        return;
    }

    bootstrapProject($root);
    $path = \OpenGenetics\Core\AdminGenerator::scaffoldApiEndpoint($root, $table);
    $rel  = str_replace($root . '/', '', $path);
    echo "  ✅ Admin endpoint: {$rel}\n";
    echo "  🔐 Protected by: ADMIN role middleware\n";
    echo "  📋 Methods: GET (paginated), POST, PUT, DELETE\n\n";
}

// ═══════════════════════════════════════════════════════
// Command: make:endpoint-ai — AI-powered endpoint scaffold
// ═══════════════════════════════════════════════════════

function cliMakeEndpointAI(string $root, ?string $name, string $description): void
{
    if (empty($name)) {
        echo "  ❌ Usage: php add/genetics make:endpoint-ai <name> \"<description>\"\n";
        echo "  Example: php add/genetics make:endpoint-ai products \"CRUD with auth and search\"\n\n";
        return;
    }

    $features = \OpenGenetics\Core\EndpointAI::analyze($description);
    echo "  🤖 AI Analysis: \"{$description}\"\n";
    echo "  " . str_repeat('─', 50) . "\n";
    foreach ($features as $feat => $enabled) {
        if ($enabled) {
            echo "  ✅ " . str_replace('needs_', '', $feat) . "\n";
        }
    }
    echo "\n";

    $path = \OpenGenetics\Core\EndpointAI::scaffold($name, $description, [], $root);
    $rel  = str_replace($root . '/', '', $path);
    echo "  ✅ Created: {$rel}\n\n";
}

// ═══════════════════════════════════════════════════════
// Commands: market:list, market:search, market:install
// ═══════════════════════════════════════════════════════

function cliMarketList(string $root, ?string $type): void
{
    echo "  🏪 Genetic Marketplace\n\n";
    $packages = \OpenGenetics\Core\Marketplace::list($type);

    if (empty($packages)) {
        echo "  ℹ️  No packages found.\n\n";
        return;
    }

    printf("  %-30s %-10s %-12s %s\n", 'Name', 'Version', 'Type', 'Description');
    echo "  " . str_repeat('─', 80) . "\n";
    foreach ($packages as $p) {
        printf("  %-30s %-10s %-12s %s\n",
            $p['name']    ?? '—',
            $p['version'] ?? '—',
            $p['type']    ?? '—',
            mb_strimwidth($p['description'] ?? '', 0, 40, '...')
        );
    }
    echo "\n  Install: php add/genetics market:install <name>\n\n";
}

function cliMarketSearch(?string $query): void
{
    if (empty($query)) {
        echo "  ❌ Usage: php add/genetics market:search <keyword>\n\n";
        return;
    }

    $results = \OpenGenetics\Core\Marketplace::search($query);

    if (empty($results)) {
        echo "  🔍 No packages found for \"{$query}\"\n\n";
        return;
    }

    echo "  🔍 Results for \"{$query}\":\n\n";
    foreach ($results as $p) {
        echo "  📦 {$p['name']} v{$p['version']}\n";
        echo "     {$p['description']}\n";
        echo "     Tags: " . implode(', ', $p['tags'] ?? []) . "\n";
        echo "     URL:  {$p['url']}\n\n";
    }
}

function cliMarketInstall(string $root, ?string $package): void
{
    if (empty($package)) {
        echo "  ❌ Usage: php add/genetics market:install <package-name>\n";
        echo "  Example: php add/genetics market:install og/notifications\n\n";
        return;
    }

    echo "  📦 Installing {$package}...\n\n";
    $result = \OpenGenetics\Core\Marketplace::install($package, $root);

    if (!$result['success']) {
        echo "  ❌ {$result['message']}\n\n";
        return;
    }

    echo "  ✅ {$result['message']}\n";
    if (!empty($result['actions'])) {
        echo "\n  Next steps:\n";
        foreach ($result['actions'] as $action) {
            echo "    → {$action}\n";
        }
    }
    echo "\n";
}

// ═══════════════════════════════════════════════════════
// Command: modules:list — Show registered modules
// ═══════════════════════════════════════════════════════

function cliModulesList(string $root): void
{
    bootstrapProject($root);
    $modules = \OpenGenetics\Core\ModuleLoader::status();

    if (empty($modules)) {
        echo "  ℹ️  No modules registered.\n";
        echo "  💡 Register in index.php: ModuleLoader::register(new MyModule());\n\n";
        return;
    }

    echo "  🧩 Registered Modules\n\n";
    foreach ($modules as $m) {
        echo "  📦 {$m['name']} v{$m['version']}\n";
        if ($m['middleware']) echo "     Middleware: " . implode(', ', $m['middleware']) . "\n";
        if ($m['commands'])   echo "     Commands:   " . implode(', ', $m['commands']) . "\n";
        echo "\n";
    }
}

