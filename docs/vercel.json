{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": null,
  "outputDirectory": "site",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/landing"
    },
    {
      "source": "/index.html",
      "destination": "/landing"
    },
    {
      "source": "/docs",
      "destination": "/overview"
    },
    {
      "source": "/docs/:path*",
      "destination": "/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/landing/index.html",
      "destination": "/landing",
      "statusCode": 301
    },
    {
      "source": "/public",
      "destination": "/landing",
      "statusCode": 301
    },
    {
      "source": "/public/:path*",
      "destination": "/landing/:path*",
      "statusCode": 301
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:css|js|svg|png|ico|woff2?))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}