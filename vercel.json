{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "cleanUrls": true,
    "trailingSlash": false,
    "redirects": [
        {
            "source": "/public",
            "destination": "/",
            "statusCode": 301
        },
        {
            "source": "/public/:path*",
            "destination": "/:path*",
            "statusCode": 301
        }
    ],
    "rewrites": [
        {
            "source": "/",
            "destination": "/docs/site/landing/index.html"
        },
        {
            "source": "/docs",
            "destination": "/docs/site/overview.html"
        },
        {
            "source": "/docs/:path*",
            "destination": "/docs/site/:path*"
        },
        {
            "source": "/images/:path*",
            "destination": "/docs/site/images/:path*"
        },
        {
            "source": "/scripts/:path*",
            "destination": "/docs/site/scripts/:path*"
        },
        {
            "source": "/styles/:path*",
            "destination": "/docs/site/styles/:path*"
        },
        {
            "source": "/landing/:path*",
            "destination": "/docs/site/landing/:path*"
        },
        {
            "source": "/:path*",
            "destination": "/docs/site/:path*"
        }
    ]
}