# ── Composer Distribution ──────────────────────────────────
# These directories/files are excluded from Composer installs
# (composer create-project, composer require) but remain in git repo.
# Maintainers who clone the repo will still see everything.

/docs               export-ignore
/tests              export-ignore
/.github            export-ignore
/.editorconfig      export-ignore
/.gitattributes     export-ignore
/phpunit.xml        export-ignore
/CHANGELOG.md       export-ignore
/CONTRIBUTING.md    export-ignore
