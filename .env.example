# ============================================
# 🧬 OpenGenetics Framework — Environment
# ============================================

# Database (use 127.0.0.1 instead of localhost for TCP; XAMPP may use port 3308)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=open-genetics-db
DB_USER=root
DB_PASS=

# JWT
JWT_SECRET=your-secret-key-change-this
JWT_EXPIRATION=86400

# App
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/open-genetics
APP_TIMEZONE=Asia/Bangkok

# CORS
CORS_ORIGIN=*

# Bcrypt
BCRYPT_COST=12
